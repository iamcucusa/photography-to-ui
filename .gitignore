# Local Claude state — never commit. Worktrees hold full repo copies +
# machine-local settings (absolute paths); local settings hold command
# allowlists. .claude/launch.json (shared config) stays tracked.
.claude/worktrees/
**/settings.local.json
.claude/settings.local.json
docs/ai-scaffolding-report.md

# Generated image derivatives (regenerated by photography-to-ui optimize:assets).
# Originals stay tracked; the responsive AVIF/WebP siblings do not.
# The manifest (src/assets-manifest.json) IS tracked — it's metadata, not an image.
photography-to-ui/public/assets/**/*.avif
photography-to-ui/public/assets/**/*.webp


{
  "radius": {
    "$type": "dimension",
    "sm": { "$value": "10px" },
    "md": { "$value": "14px" }
  },
  "divider": {
    "$type": "border",
    "subtle": {
      "$value": {
        "color": "{color.border-subtle}",
        "width": "1px",
        "style": "solid"
      },
      "$description": "Subtle divider line"
    },
    "strong": {
      "$value": {
        "color": "{color.border-strong}",
        "width": "1px",
        "style": "solid"
      },
      "$description": "Strong divider line"
    }
  },
  "focus-ring": {
    "width": {
      "$type": "dimension",
      "$value": "2px"
    },
    "offset": {
      "$type": "dimension",
      "$value": "2px"
    },
    "color": {
      "$type": "color",
      "$value": "{color.magenta.2}",
      "$description": "Focus ring color — matches accent"
    }
  }
}

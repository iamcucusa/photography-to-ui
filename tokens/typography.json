{
  "font": {
    "family": {
      "base": {
        "$type": "fontFamily",
        "$value": ["JetBrains Mono", "ui-monospace", "SFMono-Regular", "Menlo", "Monaco", "Consolas", "Liberation Mono", "Courier New", "monospace"]
      }
    },
    "weight": {
      "$type": "fontWeight",
      "regular": { "$value": 400 },
      "medium": { "$value": 500 },
      "bold": { "$value": 600 }
    }
  },
  "text": {
    "$type": "dimension",
    "xs": { "$value": "0.667rem", "$description": "~10.7px" },
    "sm": { "$value": "0.889rem", "$description": "~14.2px" },
    "md": { "$value": "1rem", "$description": "16px — base" },
    "lg": { "$value": "1.5rem", "$description": "24px" },
    "lg-plus": { "$value": "1.75rem", "$description": "~28px — between lg and xl for quote optimization" },
    "xl": { "$value": "2.25rem", "$description": "36px" },
    "xxl": { "$value": "3.375rem", "$description": "54px — use sparingly; avoid hero theatrics" }
  },
  "display": {
    "$type": "dimension",
    "xl": { "$value": "5.46rem", "$description": "~87.4px — Golden Ratio from xxl (3.375 × 1.618), for hero moments" }
  },
  "line-height": {
    "$type": "number",
    "tight": { "$value": 1.2 },
    "base": { "$value": 1.45 },
    "loose": { "$value": 1.7 }
  },
  "letter-spacing": {
    "$type": "dimension",
    "tight": { "$value": "-0.02em" },
    "normal": { "$value": "0em" }
  }
}
